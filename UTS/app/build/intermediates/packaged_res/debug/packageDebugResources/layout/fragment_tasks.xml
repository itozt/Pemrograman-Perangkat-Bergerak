<?xml version="1.0" encoding="utf-8"?>
<!-- FRAGMENT_TASKS.XML - Fragment untuk TasksFragment -->
<!-- Improved dengan better spacing, visual hierarchy, dan empty states -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white"
    tools:context=".TasksFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background_white">

            <!-- Categories Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/categories"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Today Tasks Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/today"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_today_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Future Tasks Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/future"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_future_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Completed Tasks Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/completed_today"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_completed_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="88dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- FAB with better positioning -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_task"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/add"
        android:backgroundTint="@color/primary_teal"
        android:contentDescription="@string/add_task"
        android:elevation="8dp" />

</FrameLayout>
