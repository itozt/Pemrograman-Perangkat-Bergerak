<?xml version="1.0" encoding="utf-8"?>
<!-- activity_theme.xml - Pengaturan tema dengan toolbar dan improved contrast -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white">

    <!-- Toolbar dengan back button -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_theme"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_teal"
        android:elevation="4dp"
        app:titleTextColor="@color/background_white"
        app:title="@string/nav_theme" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Theme Color"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="24dp" />

            <RadioGroup
                android:id="@+id/radio_group_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radio_theme_teal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_teal"
                    android:textSize="16sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="16dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <RadioButton
                    android:id="@+id/radio_theme_blue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_blue"
                    android:textSize="16sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="16dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <RadioButton
                    android:id="@+id/radio_theme_green"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_green"
                    android:textSize="16sp"
                    android:textColor="@color/text_dark"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </RadioGroup>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
