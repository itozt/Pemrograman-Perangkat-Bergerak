<?xml version="1.0" encoding="utf-8"?>
<!-- activity_new_task.xml - HCI-based redesign dengan header yang proper -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white">

    <!-- Header dengan "New Task" title dan close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_teal"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_close_new_task"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/background_white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Task"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/background_white"
            android:gravity="center" />

        <Space
            android:layout_width="40dp"
            android:layout_height="1dp" />

    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ========== TASK TITLE SECTION ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️  What do you need to do?"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_teal"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edit_task_title"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="@string/task_title_hint"
                    android:inputType="text"
                    android:textSize="16sp"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_secondary"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/rounded_input_background"
                    android:importantForAutofill="no"
                    android:maxLength="100" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max 100 characters"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- SECTION DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/background_light"
                android:layout_marginBottom="16dp" />

            <!-- ========== CATEGORY SECTION ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📂  Choose Category"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_teal"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_category"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/rounded_input_background" />

            </LinearLayout>

            <!-- SECTION DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/background_light"
                android:layout_marginBottom="16dp" />

            <!-- ========== DATE & TIME SECTION ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅  When do you want to complete it?"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_teal"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <!-- Date and Time in Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/text_due_date"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/rounded_input_background"
                        android:text="Select Date"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/text_due_time"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/rounded_input_background"
                        android:text="Select Time"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Click to set date and time"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- SECTION DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/background_light"
                android:layout_marginBottom="16dp" />

            <!-- ========== REMINDER SECTION ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <CheckBox
                    android:id="@+id/checkbox_reminder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔔  Enable Reminder"
                    android:textSize="13sp"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/text_reminder_time"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/rounded_input_background"
                    android:text="Select Reminder Time"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:visibility="gone"
                    android:enabled="false" />

            </LinearLayout>

            <!-- SECTION DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/background_light"
                android:layout_marginBottom="16dp" />

            <!-- ========== REPEAT SECTION ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔁  Repeat Pattern"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_teal"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_repeat_type"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/rounded_input_background" />

            </LinearLayout>

            <!-- SECTION DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/background_light"
                android:layout_marginBottom="16dp" />

            <!-- ========== NOTES SECTION ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝  Add Notes (Optional)"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_teal"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edit_notes"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="@string/hint_notes"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_secondary"
                    android:background="@drawable/rounded_input_background"
                    android:importantForAutofill="no"
                    android:maxLength="500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max 500 characters"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Action Buttons Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:background="@color/background_light"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_task"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:layout_marginEnd="8dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_task"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/save"
            android:backgroundTint="@color/primary_teal"
            android:textColor="@color/background_white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
