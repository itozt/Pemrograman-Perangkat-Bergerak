<?xml version="1.0" encoding="utf-8"?>
<!-- nav_header.xml - Header untuk Navigation Drawer dengan HCI improvements -->
<!-- Lokasi: app/src/main/res/layout/nav_header.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="@color/primary_teal"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Logo dengan elevation untuk depth -->
    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/logo"
        android:scaleType="centerInside"
        android:contentDescription="App Logo"
        android:elevation="2dp" />

    <!-- App Name dengan better typography -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="To-Do List"
        android:textColor="@color/background_white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:letterSpacing="0.02" />

    <!-- Subtitle untuk better context -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Personal Task Manager"
        android:textColor="@color/background_white"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:alpha="0.85" />

</LinearLayout>
