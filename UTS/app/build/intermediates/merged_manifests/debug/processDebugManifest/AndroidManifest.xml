<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.todolistpersonal"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="35" />

    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <permission
        android:name="com.example.todolistpersonal.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.todolistpersonal.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="com.example.todolistpersonal.ToDoApplication"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.ToDoListPersonal" >

        <!-- Main Activity - Launcher Activity dengan Drawer dan Bottom Navigation -->
        <activity
            android:name="com.example.todolistpersonal.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ToDoListPersonal" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Tasks Screen Activity -->
        <activity
            android:name="com.example.todolistpersonal.TasksActivity"
            android:exported="false"
            android:label="Tasks"
            android:theme="@style/Theme.ToDoListPersonal" />

        <!-- Calendar Screen Activity -->
        <activity
            android:name="com.example.todolistpersonal.CalendarActivity"
            android:exported="false"
            android:label="Calendar"
            android:theme="@style/Theme.ToDoListPersonal" />

        <!-- New Task Dialog Activity -->
        <activity
            android:name="com.example.todolistpersonal.NewTaskActivity"
            android:exported="false"
            android:theme="@style/Theme.ToDoListPersonal.Dialog" />

        <!-- Task Detail Screen Activity -->
        <activity
            android:name="com.example.todolistpersonal.TaskDetailActivity"
            android:exported="false"
            android:label="Task Detail"
            android:theme="@style/Theme.ToDoListPersonal" />

        <!-- Theme Selection Activity -->
        <activity
            android:name="com.example.todolistpersonal.ThemeActivity"
            android:exported="false"
            android:label="Theme"
            android:theme="@style/Theme.ToDoListPersonal" />

        <!-- Settings Activity -->
        <activity
            android:name="com.example.todolistpersonal.SettingsActivity"
            android:exported="false"
            android:label="Settings"
            android:theme="@style/Theme.ToDoListPersonal" />
        <activity
            android:name="androidx.compose.ui.tooling.PreviewActivity"
            android:exported="true" />
        <activity
            android:name="androidx.activity.ComponentActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.example.todolistpersonal.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>